//-------------------------------------------------
// FILE: meta_shoreside.moos
// NAME: Charles Benjamin
//-------------------------------------------------

ServerHost = localhost
ServerPort = $(MOOS_PORT)
Community  = shoreside

#include plugs.moos <origin_warp>

//----------------------------------------------------
ProcessConfig = ANTLER
{
  MSBetweenLaunches = 200

  Run = MOOSDB           @ NewConsole = false
  Run = pRealm           @ NewConsole = false
  Run = uProcessWatch    @ NewConsole = false
  Run = pShare           @ NewConsole = false
  Run = pHostInfo        @ NewConsole = false
  Run = uFldShoreBroker  @ NewConsole = false
  Run = uFldNodeComms    @ NewConsole = false
  Run = uTimerScript     @ NewConsole = false
  Run = pEchoVar         @ NewConsole = false
  Run = pMissionEval     @ NewConsole = false
  Run = pAutoPoke        @ NewConsole = false
#ifdef LAUNCH_GUI yes
  Run = pMarineViewer    @ NewConsole = false
#else
  Run = pMissionHash     @ NewConsole = false
#endif
}

#include plugs.moos <pHostInfo>
#include plugs.moos <pShare>
#include plugs.moos <uProcessWatch>

//----------------------------------------------------
// pEchoVar Config Block

// Preserve the exact update value as well as its result so ordered recovery
// cases cannot pass on an unrelated warning or later generic success.

ProcessConfig = pEchoVar
{
  AppTick   = 10
  CommsTick = 10

  FLIP:bad_pwt = source_variable = IVPHELM_UPDATE_RESULT
  FLIP:bad_pwt = dest_variable   = SHADOW_BAD_PWT_REJECTED
  FLIP:bad_pwt = bhv == shadow_contact
  FLIP:bad_pwt = var == SHADOW_UPDATES
  FLIP:bad_pwt = result == param_error
  FLIP:bad_pwt = val == pwt_outer_dist=-5
  FLIP:bad_pwt = result -> result

  FLIP:pwt_120 = source_variable = IVPHELM_UPDATE_RESULT
  FLIP:pwt_120 = dest_variable   = SHADOW_PWT_120_ACCEPTED
  FLIP:pwt_120 = bhv == shadow_contact
  FLIP:pwt_120 = var == SHADOW_UPDATES
  FLIP:pwt_120 = result == success
  FLIP:pwt_120 = val == pwt_outer_dist=120
  FLIP:pwt_120 = result -> result

  FLIP:ghost = source_variable = IVPHELM_UPDATE_RESULT
  FLIP:ghost = dest_variable   = SHADOW_GHOST_ACCEPTED
  FLIP:ghost = bhv == shadow_contact
  FLIP:ghost = var == SHADOW_UPDATES
  FLIP:ghost = result == success
  FLIP:ghost = val == contact=ghost
  FLIP:ghost = result -> result

  FLIP:ben = source_variable = IVPHELM_UPDATE_RESULT
  FLIP:ben = dest_variable   = SHADOW_BEN_ACCEPTED
  FLIP:ben = bhv == shadow_contact
  FLIP:ben = var == SHADOW_UPDATES
  FLIP:ben = result == success
  FLIP:ben = val == contact=ben
  FLIP:ben = result -> result
}

//----------------------------------------------------
// pAutoPoke Config Block

ProcessConfig = pAutoPoke
{
  AppTick   = 2
  CommsTick = 2

  flag = DEPLOY_ALL=true
  flag = MOOS_MANUAL_OVERRIDE_ALL=false
  flag = TEST_EVAL_READY=false
  flag = BHV_ERROR_SEEN=false
  flag = BHV_WARNING_SEEN=false
  flag = SHADOW_BAD_PWT_REJECTED_SEEN=false
  flag = SHADOW_PWT_120_ACCEPTED_SEEN=false
  flag = SHADOW_GHOST_ACCEPTED_SEEN=false
  flag = SHADOW_BEN_ACCEPTED_SEEN=false
  flag = SHADOW_CONTACT_X=0
  flag = SHADOW_CONTACT_Y=0
  flag = SHADOW_CONTACT_SPEED=0
  flag = SHADOW_CONTACT_HEADING=0
  flag = SHADOW_RELEVANCE=0
  flag = ABE_NAV_SPEED=0
  flag = ABE_NAV_HEADING=0
  flag = ABE_NAV_X=0
  flag = ABE_NAV_Y=0
  flag = BEN_NAV_SPEED=0
  flag = BEN_NAV_HEADING=0
  flag = BEN_NAV_X=0
  flag = BEN_NAV_Y=0

  required_nodes = 2
}

//----------------------------------------------------
// uTimerScript Config Block

ProcessConfig = uTimerScript
{
  AppTick   = 2
  CommsTick = 2

  condition = DEPLOY_ALL = true

  event = var=TEST_EVAL_READY, val=true, time=45
}

//----------------------------------------------------
// pMissionEval Config Block

ProcessConfig = pMissionEval
{
  AppTick   = 4
  CommsTick = 4

  mailflag = @BHV_ERROR#BHV_ERROR_SEEN=true
  mailflag = @BHV_WARNING#BHV_WARNING_SEEN=true

  lead_condition = TEST_EVAL_READY = true
  pass_condition = TEST_EVAL_READY = true
  pass_condition = SHADOW_RELEVANCE > 0
  pass_condition = SHADOW_CONTACT_SPEED >= 1.0
  pass_condition = SHADOW_CONTACT_HEADING >= 70
  pass_condition = SHADOW_CONTACT_HEADING <= 110
  pass_condition = ABE_NAV_SPEED >= 1.0
  pass_condition = ABE_NAV_SPEED <= 2.0
  pass_condition = ABE_NAV_HEADING >= 70
  pass_condition = ABE_NAV_HEADING <= 110
  pass_condition = BEN_NAV_SPEED >= 1.0
  pass_condition = BEN_NAV_HEADING >= 70
  pass_condition = BEN_NAV_HEADING <= 110
  pass_condition = BHV_WARNING_SEEN = false
  pass_condition = BHV_ERROR_SEEN = false

  result_flag = MISSION_EVALUATED = true
  pass_flag   = SAY_MOOS = pass
  fail_flag   = SAY_MOOS = fail

  mission_form = shadow_behavior_tests
  mission_mod  = $(MMOD:=static_shadow_pass)

  report_file   = results.txt
  report_column = grade=$[GRADE]
  report_column = form=$[MISSION_FORM]
  report_column = mmod=$[MMOD]
  report_column = eval=$[TEST_EVAL_READY]
  report_column = relevance=$[SHADOW_RELEVANCE]
  report_column = shdw_spd=$[SHADOW_CONTACT_SPEED]
  report_column = shdw_hdg=$[SHADOW_CONTACT_HEADING]
  report_column = abe_spd=$[ABE_NAV_SPEED]
  report_column = abe_hdg=$[ABE_NAV_HEADING]
  report_column = ben_spd=$[BEN_NAV_SPEED]
  report_column = ben_hdg=$[BEN_NAV_HEADING]
  report_column = abe_x=$[ABE_NAV_X]
  report_column = abe_y=$[ABE_NAV_Y]
  report_column = ben_x=$[BEN_NAV_X]
  report_column = ben_y=$[BEN_NAV_Y]
  report_column = warning=$[BHV_WARNING_SEEN]
  report_column = bhv_error=$[BHV_ERROR_SEEN]
  report_column = mhash=$[MHASH_SHORT]
}

//----------------------------------------------------
// uFldShoreBroker Config Block

ProcessConfig = uFldShoreBroker
{
  AppTick   = 1
  CommsTick = 1

  qbridge  = DEPLOY, RETURN, NODE_REPORT, NODE_MESSAGE
  qbridge  = MOOS_MANUAL_OVERRIDE
  qbridge  = SHADOW_UPDATES, TEST_EVAL_READY
  qbridge  = SHADOW_CONTACT_X, SHADOW_CONTACT_Y
  qbridge  = SHADOW_CONTACT_SPEED, SHADOW_CONTACT_HEADING, SHADOW_RELEVANCE
  qbridge  = ABE_NAV_SPEED, ABE_NAV_HEADING, ABE_NAV_X, ABE_NAV_Y
  qbridge  = BEN_NAV_SPEED, BEN_NAV_HEADING, BEN_NAV_X, BEN_NAV_Y
  qbridge  = IVPHELM_UPDATE_RESULT, BHV_WARNING, BHV_ERROR
}

//----------------------------------------------------
// uFldNodeComms Config Block

ProcessConfig = uFldNodeComms
{
  AppTick   = 2
  CommsTick = 2

  comms_range      = 500
  critical_range   = 25
  min_msg_interval = 10
  max_msg_length   = 1000
  groups           = true
}

//----------------------------------------------------
// pLogger Config Block

ProcessConfig = pLogger
{
  AppTick       = 10
  CommsTick     = 10

  File          = XLOG_SHORESIDE
  PATH          = ./
  AsyncLog      = true
  FileTimeStamp = true

  Log = SHADOW_CONTACT_X @ 0 nosync
  Log = SHADOW_CONTACT_Y @ 0 nosync
  Log = SHADOW_CONTACT_SPEED @ 0 nosync
  Log = SHADOW_CONTACT_HEADING @ 0 nosync
  Log = SHADOW_RELEVANCE @ 0 nosync
  Log = ABE_NAV_SPEED @ 0 nosync
  Log = ABE_NAV_HEADING @ 0 nosync
  Log = ABE_NAV_X @ 0 nosync
  Log = ABE_NAV_Y @ 0 nosync
  Log = BEN_NAV_SPEED @ 0 nosync
  Log = BEN_NAV_HEADING @ 0 nosync
  Log = BEN_NAV_X @ 0 nosync
  Log = BEN_NAV_Y @ 0 nosync
  Log = IVPHELM_UPDATE_RESULT @ 0 nosync
  Log = SHADOW_BAD_PWT_REJECTED @ 0 nosync
  Log = SHADOW_PWT_120_ACCEPTED @ 0 nosync
  Log = SHADOW_GHOST_ACCEPTED @ 0 nosync
  Log = SHADOW_BEN_ACCEPTED @ 0 nosync
  Log = BHV_WARNING @ 0 nosync
  Log = BHV_ERROR @ 0 nosync
  Log = BHV_ERROR_SEEN @ 0 nosync
  Log = MISSION_EVALUATED @ 0 nosync
  Log = NODE_REPORT @ 0 nosync
}

//----------------------------------------------------
// pMarineViewer Config Block

ProcessConfig = pMarineViewer
{
  AppTick   = 4
  CommsTick = 4

  tiff_file = MIT_SP.tif
  set_pan_x = 40
  set_pan_y = -80
  zoom      = 1.1

  vehicles_shape_scale = 1.0
  vehicles_name_mode   = names

  app_logging = true
  hash_delta  = true

  scope = NODE_REPORT
  scope = SHADOW_RELEVANCE
  scope = SHADOW_CONTACT_SPEED
  scope = SHADOW_CONTACT_HEADING
  scope = ABE_NAV_SPEED
  scope = ABE_NAV_HEADING
  scope = BEN_NAV_SPEED
  scope = BEN_NAV_HEADING
  scope = BHV_ERROR_SEEN
}
