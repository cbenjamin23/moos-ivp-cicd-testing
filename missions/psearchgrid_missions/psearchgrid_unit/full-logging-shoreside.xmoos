ProcessConfig = pLogger
{
  AppTick   = 10
  CommsTick = 10

  File     = LOG_psearchgrid_unit
  PATH     = ./
  AsyncLog = true

  Log = TEST_EVAL_READY @ 0 nosync
  Log = NODE_REPORT @ 0 nosync
  Log = NODE_REPORT_LOCAL @ 0 nosync
  Log = PSG_RESET_GRID @ 0 nosync
  Log = VIEW_GRID @ 0 nosync
  Log = VIEW_GRID_DELTA @ 0 nosync
  Log = SEARCH_GRID @ 0 nosync
  Log = SEARCH_GRID_DELTA @ 0 nosync
  Log = MISSION_EVALUATED @ 0 nosync
}
