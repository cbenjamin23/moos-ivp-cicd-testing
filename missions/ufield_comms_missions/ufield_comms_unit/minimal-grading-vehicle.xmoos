ProcessConfig = pLogger
{
  AppTick       = 5
  CommsTick     = 5

  File          = LOG_%(VNAME)
  PATH          = ./
  AsyncLog      = true
  FileTimeStamp = true
  LogAuxSrc     = true

  WildCardLogging = false
  Log = NODE_BROKER_ACK @ 0 nosync
  Log = NODE_PSHARE_VARS @ 0 nosync
  Log = PSHARE_CMD @ 0 nosync
  Log = TRY_SHORE_HOST @ 0 nosync
}
