Behavior = BHV_Loiter
{
  name      = loiter
  pwt       = 100
  condition = MODE == ACTIVE
  updates   = LOITER_UPDATES
  endflag   = LOITER_DONE = true
  endflag   = DESIRED_SPEED = 0
  runxflag  = EMPTY_SPEC_RUN = true

  perpetual = true
  speed     = $(STOCK_SPD)

  clockwise      = true
  capture_radius = 4.0
  slip_radius    = 12.0
  acquire_dist   = 10
}
