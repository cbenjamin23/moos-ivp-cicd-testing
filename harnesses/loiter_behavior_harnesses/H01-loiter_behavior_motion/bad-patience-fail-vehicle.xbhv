Behavior = BHV_Loiter
{
  name      = loiter
  pwt       = 100
  condition = MODE == ACTIVE
  updates   = LOITER_UPDATES
  endflag   = LOITER_DONE = true
  endflag   = DESIRED_SPEED = 0

  perpetual = true
  speed     = $(STOCK_SPD)

  patience       = 100
  clockwise      = true
  capture_radius = 4.0
  slip_radius    = 12.0
  acquire_dist   = 10
  polygon        = radial:: x=12, y=-121, radius=18, pts=8, snap=1, label=LOITER_BAD_PATIENCE
}
