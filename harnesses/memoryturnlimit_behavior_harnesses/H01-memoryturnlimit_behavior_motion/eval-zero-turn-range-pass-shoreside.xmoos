ProcessConfig = pMissionEval
{
  AppTick   = 4
  CommsTick = 4

  mailflag = @BHV_WARNING#BHV_WARNING_SEEN=true
  mailflag = @BHV_ERROR#BHV_ERROR_SEEN=true

  lead_condition = (EVAL_TIME = true) or (MISSION_TIMEOUT = true)
  pass_condition = EVAL_TIME = true
  pass_condition = MEM_HDG_AVG >= 88
  pass_condition = MEM_HDG_AVG <= 105
  pass_condition = NAV_HEADING >= 88
  pass_condition = NAV_HEADING <= 105
  pass_condition = NAV_SPEED >= 0.7
  pass_condition = HEADING_MISMATCH >= 75
  pass_condition = HEADING_MISMATCH <= 95
  pass_condition = BHV_WARNING_SEEN = false
  pass_condition = BHV_ERROR_SEEN = false

  result_flag = MISSION_EVALUATED = true
  pass_flag   = SAY_MOOS = pass
  fail_flag   = SAY_MOOS = fail

  mission_form = memoryturnlimit_behavior_tests
  mission_mod  = $(MMOD:=zero_turn_range_pass)

  report_file   = results.txt
  report_column = grade=$[GRADE]
  report_column = form=$[MISSION_FORM]
  report_column = mmod=$[MMOD]
  report_column = eval=$[EVAL_TIME]
  report_column = timeout=$[MISSION_TIMEOUT]
  report_column = heading=$[NAV_HEADING]
  report_column = nav_speed=$[NAV_SPEED]
  report_column = mem_hdg_avg=$[MEM_HDG_AVG]
  report_column = heading_mismatch=$[HEADING_MISMATCH]
  report_column = warning=$[BHV_WARNING_SEEN]
  report_column = bhv_error=$[BHV_ERROR_SEEN]
  report_column = mhash=$[MHASH_SHORT]
}
