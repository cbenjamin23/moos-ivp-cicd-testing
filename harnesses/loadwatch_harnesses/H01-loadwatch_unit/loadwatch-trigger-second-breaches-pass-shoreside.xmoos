//-------------------------------------------------
// FILE: loadwatch-trigger-second-breaches-pass-shoreside.xmoos
// NAME: Charles Benjamin
//-------------------------------------------------

ProcessConfig = uTimerScript
{
  AppTick   = 4
  CommsTick = 4

  event = var=UTILITY_ITER_GAP, val=3.5, time=1.0
  event = var=UTILITY_ITER_GAP, val=3.7, time=2.0
  event = var=TEST_EVAL_READY, val=true, time=7.0
}

ProcessConfig = uLoadWatch
{
  AppTick   = 4
  CommsTick = 4

  thresh = app=ANY, gapthresh=3.0
  near_breach_thresh = 0.5
  breach_trigger = 1
}

ProcessConfig = pMissionEval
{
  AppTick   = 4
  CommsTick = 4

  lead_condition = TEST_EVAL_READY = true
  pass_condition = ULW_BREACH = true
  pass_condition = ULW_BREACH_COUNT >= 1
  pass_condition = ULW_NEAR_BREACH_COUNT >= 2

  result_flag  = MISSION_EVALUATED = true
  mission_form = loadwatch_unit
  mission_mod  = loadwatch_trigger_second_breaches_pass

  prereport_column = form=$[MISSION_FORM]
  prereport_column = mmod=$[MMOD]
  report_column    = grade=$[GRADE]
  report_column    = eval=$[TEST_EVAL_READY]
  report_column    = breach=$[ULW_BREACH]
  report_column    = load_breaches=$[ULW_BREACH_COUNT]
  report_column    = near_breaches=$[ULW_NEAR_BREACH_COUNT]
  report_column    = mhash=$[MHASH_SHORT]
  report_file      = results.txt
}
