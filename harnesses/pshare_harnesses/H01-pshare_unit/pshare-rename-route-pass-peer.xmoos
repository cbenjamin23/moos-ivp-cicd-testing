ProcessConfig = pShare
{
  AppTick   = 10
  CommsTick = 10

  Output = src_name=ROUTE_TEST,dest_name=ROUTE_RENAMED,route=127.0.0.1:$(SHORE_PSHARE)
  Output = src_name=PSHARE_CASE_DONE,route=127.0.0.1:$(SHORE_PSHARE)
}

ProcessConfig = uTimerScript
{
  AppTick   = 4
  CommsTick = 4

  event = var=ROUTE_TEST, val=bravo, time=2.0
  event = var=PSHARE_CASE_DONE, val=true, time=4.0
}
