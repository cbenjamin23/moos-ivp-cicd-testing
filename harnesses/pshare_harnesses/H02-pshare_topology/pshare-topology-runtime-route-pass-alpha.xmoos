ProcessConfig = pShare
{
  AppTick   = 10
  CommsTick = 10
}

ProcessConfig = uTimerScript
{
  AppTick   = 4
  CommsTick = 4

  event = var=PSHARE_CMD, val="cmd=output,src_name=RUNTIME_SRC,dest_name=RUNTIME_RX,route=127.0.0.1:$(SHORE_PSHARE)", time=18.0
  event = var=RUNTIME_SRC, val=runtime, time=22.0
}
