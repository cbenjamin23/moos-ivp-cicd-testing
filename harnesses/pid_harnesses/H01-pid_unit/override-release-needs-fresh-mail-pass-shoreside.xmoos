//-------------------------------------------------
// FILE: override-release-needs-fresh-mail-pass-shoreside.xmoos
// NAME: Charles Benjamin
//-------------------------------------------------

ProcessConfig = uTimerScript
{
  AppTick   = 4
  CommsTick = 4

  condition = DEPLOY_ALL = true

  event = var=MOOS_MANUAL_OVERRIDE, val=true,  time=0.5
  event = var=DESIRED_HEADING,      val=90,    time=1.0
  event = var=DESIRED_SPEED,        val=2,     time=1.0
  event = var=NAV_HEADING,          val=0,     time=1.0
  event = var=NAV_SPEED,            val=0,     time=1.0
  event = var=MOOS_MANUAL_OVERRIDE, val=false, time=3.0
  event = var=TEST_EVAL_READY,      val=true,  time=5.0
}

ProcessConfig = pMissionEval
{
  AppTick   = 4
  CommsTick = 4

  lead_condition = TEST_EVAL_READY = true
  pass_condition = DESIRED_RUDDER_PID >= -0.1
  pass_condition = DESIRED_RUDDER_PID <= 0.1
  pass_condition = DESIRED_THRUST_PID >= -0.1
  pass_condition = DESIRED_THRUST_PID <= 0.1

  result_flag  = MISSION_EVALUATED = true
  mission_form = pid_unit
  mission_mod  = override_release_needs_fresh_mail_pass

  prereport_column = form=$[MISSION_FORM]
  prereport_column = mmod=$[MMOD]
  report_column    = grade=$[GRADE]
  report_column    = eval=$[TEST_EVAL_READY]
  report_column    = rudder=$[DESIRED_RUDDER_PID]
  report_column    = thrust=$[DESIRED_THRUST_PID]
  report_column    = control=$[PID_HAS_CONTROL]
  report_column    = mhash=$[MHASH_SHORT]
  report_file      = results.txt
}
