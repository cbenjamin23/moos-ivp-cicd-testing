ProcessConfig = uFldShoreBroker
{
  AppTick   = 2
  CommsTick = 2

  qbridge = NODE_REPORT, NODE_MESSAGE, ACK_MESSAGE
  bridge  = src=STATUS_$v, alias=STATUS
  bridge  = src=INDEX_$N,  alias=INDEXED_STATUS
}
