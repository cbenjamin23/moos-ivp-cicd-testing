Behavior = BHV_Shadow
{
  name      = shadow_contact
  pwt       = 100
  condition = MODE == ACTIVE
  condition = SHADOW = true
  updates   = SHADOW_UPDATES

           contact = unset_ok
    pwt_outer_dist = 0
  on_no_contact_ok = true
       extrapolate = true
             decay = 30,60

   hdg_peakwidth = 25
   hdg_basewidth = 170
   spd_peakwidth = 0.3
    spd_basewidth = 1.5
}
