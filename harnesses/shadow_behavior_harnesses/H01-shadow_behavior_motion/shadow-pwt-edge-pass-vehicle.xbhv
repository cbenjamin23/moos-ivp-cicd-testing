Behavior = BHV_Shadow
{
  name      = shadow_contact
  pwt       = 100
  condition = MODE == ACTIVE
  condition = SHADOW = true
  updates   = SHADOW_UPDATES

           contact = unset_ok
    pwt_outer_dist = 100
  on_no_contact_ok = true
       extrapolate = true
             decay = 30,60

 heading_peakwidth = 20
 heading_basewidth = 160
  speed_peakwidth = 0.1
   speed_basewidth = 2.0
}
