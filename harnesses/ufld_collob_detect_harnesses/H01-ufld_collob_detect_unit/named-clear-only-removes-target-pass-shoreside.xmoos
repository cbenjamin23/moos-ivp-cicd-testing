ProcessConfig = ANTLER
{
  MSBetweenLaunches = 80
  Run = MOOSDB @ NewConsole = false
  Run = pRealm @ NewConsole = false
  Run = pLogger @ NewConsole = false
  Run = uFldCollObDetect @ NewConsole = false
  Run = uTimerScript @ NewConsole = false
  Run = pMissionEval @ NewConsole = false
}

ProcessConfig = uFldCollObDetect
{
  AppTick = 10
  CommsTick = 10
  collision_dist = 1
  near_miss_dist = 5
  encounter_dist = 15
  encounter_flag = COD_ENCOUNTER=$VNAME:$ID:$DIST:$ENC_CNT
  near_miss_flag = COD_NEAR=$VNAME:$ID:$DIST:$MISS_CNT
  collision_flag = COD_COLLISION=$VNAME:$ID:$DIST:$COLL_CNT
}

ProcessConfig = uTimerScript
{
  AppTick = 4
  CommsTick = 4
  block_on = pMissionEval, uFldCollObDetect
  event = var=KNOWN_OBSTACLE, val="pts={-5,-5:5,-5:5,5:-5,5},label=obs1", time=0.4
  event = var=KNOWN_OBSTACLE, val="pts={35,-5:45,-5:45,5:35,5},label=obs2", time=0.5
  event = var=KNOWN_OBSTACLE_CLEAR, val="obs1", time=5.2
  event = var=NODE_REPORT, val="NAME=alpha,TYPE=KAYAK,GROUP=red,UTC_TIME=100,X=65,Y=0,LAT=43.825300,LON=-70.330400,SPD=0,HDG=0", time=5.7
  event = var=NODE_REPORT, val="NAME=alpha,TYPE=KAYAK,GROUP=red,UTC_TIME=100,X=45.5,Y=0,LAT=43.825300,LON=-70.330400,SPD=0,HDG=0", time=6.2
  event = var=NODE_REPORT, val="NAME=alpha,TYPE=KAYAK,GROUP=red,UTC_TIME=100,X=65,Y=0,LAT=43.825300,LON=-70.330400,SPD=0,HDG=0", time=6.8
  event = var=TEST_EVAL_READY, val=true, time=8.5
}

ProcessConfig = pMissionEval
{
  AppTick = 4
  CommsTick = 4
  lead_condition = TEST_EVAL_READY = true
  pass_condition = COD_COLLISION = alpha:obs2:0.5:1
  pass_condition = COD_ENCOUNTER = alpha:obs2:0.5:1
  result_flag = MISSION_EVALUATED = true
  mission_form = ufield_app_unit
  report_column = grade=$[GRADE]
  report_column = eval=$[TEST_EVAL_READY]
  report_column = collision=$[COD_COLLISION]
  report_column = encounter=$[COD_ENCOUNTER]
  report_file = results.txt
}
