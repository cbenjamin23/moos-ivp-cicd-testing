ProcessConfig = pObstacleMgr
{
  AppTick   = 4
  CommsTick = 4

  given_obstacle = pts={27,-52:45,-52:45,-68:27,-68},label=ob_noavoid

  obstacles_color = green
  post_view_polys = true

  given_max_duration = 1000
}

ProcessConfig = uTimerScript
{
  AppTick   = 2
  CommsTick = 2

  condition = OBM_CONNECT = true

  // Post obstacle alerts onto an unused variable so no avoid behavior spawns.
  event = var=OBM_ALERT_REQUEST, val="name=avd_,update_var=DISABLED_ALERT,alert_range=22", time=1
}
