Behavior = BHV_Trail
{
  name      = trail_contact
  pwt       = 100
  condition = MODE == ACTIVE
  condition = TRAIL = true
  updates   = TRAIL_UPDATES

              contact = ben
       pwt_outer_dist = 0
            nm_radius = 18
               radius = 8
          trail_angle = west
          trail_range = 45
     trail_angle_type = relative
     on_no_contact_ok = true
          extrapolate = true
                decay = 30,60
}
