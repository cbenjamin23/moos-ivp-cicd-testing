Behavior = BHV_Trail
{
  name      = trail_contact
  pwt       = 100
  condition = MODE == ACTIVE
  condition = TRAIL = true
  updates   = TRAIL_UPDATES

              contact = ben
       pwt_outer_dist = 0
            nm_radius = 14
               radius = 5
          trail_angle = 180
          trail_range = 50
  mod_trail_range_pct = 50
     trail_angle_type = relative
     on_no_contact_ok = true
          extrapolate = true
                decay = 30,60
}
