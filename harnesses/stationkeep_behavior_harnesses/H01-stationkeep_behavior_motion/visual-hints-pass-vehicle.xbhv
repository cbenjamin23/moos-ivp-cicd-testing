Behavior = BHV_StationKeep
{
  name      = station_keep
  pwt       = 100
  condition = MODE == ACTIVE
  updates   = STATIONKEEP_UPDATES

  point         = x=12,y=-121
  inner_radius  = 4
  outer_radius  = 15
  outer_speed   = 1.2
  transit_speed = $(STOCK_SPD)

  visual_hints = vertex_color=yellow, edge_color=cyan
  visual_hints = vertex_size=2, edge_size=2
  visual_hints = label_color=white
}
