Behavior = BHV_StationKeep
{
  name      = station_keep
  pwt       = 100
  condition = MODE == ACTIVE
  updates   = STATIONKEEP_UPDATES

  center_activate = true
  inner_radius    = 4
  outer_radius    = 15
  outer_speed     = 1.2
  transit_speed   = $(STOCK_SPD)

  visual_hints = vertex_color=white, edge_color=white
  visual_hints = vertex_size=1, edge_size=1
  visual_hints = label_color=white
}
