ProcessConfig = uTimerScript
{
  AppTick   = 2
  CommsTick = 2

  condition = DEPLOY_ALL = true

  event = var=KNOWN_OBSTACLE, val="pts={29,-53:43,-53:43,-67:29,-67},label=ob_lane", time=1
  event = var=EVAL_ARMED, val=true, time=2
  event = var=TEST_EVAL_READY, val=true, time=20
}

ProcessConfig = pMissionEval
{
  AppTick   = 4
  CommsTick = 4

  lead_condition = (EVAL_ARMED = true) or (TEST_EVAL_READY = true)
  pass_condition = EVAL_ARMED = true

  lead_condition = (IVPHELM_STATE = MALCONFIG) or (TEST_EVAL_READY = true)
  pass_condition = IVPHELM_STATE = MALCONFIG
  pass_condition = TEST_EVAL_READY = false

  result_flag = MISSION_EVALUATED = true
  pass_flag   = SAY_MOOS = pass
  fail_flag   = SAY_MOOS = fail

  mission_form = obstacle_behavior_motion_tests
  mission_mod  = $(MMOD:=bad_config_fail)

  report_file   = results.txt
  report_column = grade=$[GRADE]
  report_column = form=$[MISSION_FORM]
  report_column = mmod=$[MMOD]
  report_column = eval=$[IVPHELM_STATE]
  report_column = expected=helm_malconfig
  report_column = armed=$[EVAL_ARMED]
  report_column = deadline=$[TEST_EVAL_READY]
  report_column = helm_state=$[IVPHELM_STATE]
  report_column = mhash=$[MHASH_SHORT]
}
