Behavior = BHV_FixedTurn
{
  name      = fixed_turn
  pwt       = 100
  condition = MODE == ACTIVE
  condition = FIX_TURN = true
  updates   = FTURN_UPDATE
  endflag   = TURNING_TIME = $[TURN_TIME]
  endflag   = TURNING_DIST = $[TURN_DIST]

  perpetual = false
  fix_turn  = 180
  mod_hdg   = 60
  turn_dir  = port
  speed     = 1.2

  turn_spec = spd=1.4, mhdg=25, fhdg=90, tdir=star, flag=TURN_ONE=true, flag=FT_DONE=true

  stale_nav_thresh = 5
}
