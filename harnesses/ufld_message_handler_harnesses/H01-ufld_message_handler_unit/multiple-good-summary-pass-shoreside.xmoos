ProcessConfig = uTimerScript
{
  AppTick = 4
  CommsTick = 4
  block_on = pMissionEval, uFldMessageHandler
  event = var=EXPECT_SUMMARY, val="total=2,valid=2,rejected=0", time=0.1
  event = var=NODE_MESSAGE, val="src_node=alpha,dest_node=shoreside,var_name=HANDLED_RESULT,string_val=first_ok", time=1.0
  event = var=NODE_MESSAGE, val="src_node=bravo,dest_node=shoreside,var_name=HANDLED_RESULT,string_val=second_ok", time=1.5
  event = var=TEST_EVAL_READY, val=true, time=6.0
}

ProcessConfig = pMissionEval
{
  AppTick = 4
  CommsTick = 4
  lead_condition = TEST_EVAL_READY = true
  pass_condition = HANDLED_RESULT = second_ok
  pass_condition = UMH_SUMMARY_MSGS = $ (EXPECT_SUMMARY)
  result_flag = MISSION_EVALUATED = true
  mission_form = ufield_app_unit
  report_column = grade=$[GRADE]
  report_column = eval=$[TEST_EVAL_READY]
  report_column = result=$[HANDLED_RESULT]
  report_column = summary=$[UMH_SUMMARY_MSGS]
  report_file = results.txt
}
