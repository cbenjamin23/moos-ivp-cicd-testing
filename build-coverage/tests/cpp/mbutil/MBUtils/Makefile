	cd /Users/charlesbenjamin/moos-ivp-cicd-testing/build-coverage && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
